# Copy to .env for local development. Never commit the real .env file
# (already covered by .gitignore).

ENVIRONMENT=dev

# Local docker-compose Postgres by default — swap for a Neon dev branch
# connection string (still postgresql+asyncpg://... scheme) when needed.
DATABASE_URL=postgresql+asyncpg://bookmarks:bookmarks@localhost:5432/bookmarks

# Generate a real secret locally with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-me-with-a-random-64-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ALLOWED_ORIGINS=http://localhost:5173

LOG_LEVEL=INFO
