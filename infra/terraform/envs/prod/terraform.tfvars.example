# Copy to terraform.tfvars (gitignored) for local runs, or supply via
# -var/-var-file/TF_VAR_* in CI. Never commit real values here.

aws_region = "eu-north-1"

environment_variables = {
  ENVIRONMENT               = "prod"
  DATABASE_URL              = "postgresql+asyncpg://user:pass@host/dbname"
  JWT_SECRET_KEY            = "replace-with-a-real-random-64-byte-secret"
  JWT_ALGORITHM             = "HS256"
  ACCESS_TOKEN_EXPIRE_MINUTES = "15"
  REFRESH_TOKEN_EXPIRE_DAYS   = "30"
  CORS_ALLOWED_ORIGINS      = "https://example.pages.dev"
  LOG_LEVEL                 = "INFO"
}
